VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key

# AI clothing suggestions (optional): the Anthropic API key is a SERVER-SIDE
# secret for the `ai-suggestions` Supabase Edge Function, never a client var.
# Set it with: supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# Without it, the app falls back to the built-in local scoring engine.
